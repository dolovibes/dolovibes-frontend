# ============================================
# DOLOVIBES FRONTEND - Variables de Entorno
# ============================================

# --------------------------------------------
# ENTORNO
# --------------------------------------------
NODE_ENV=development

# --------------------------------------------
# STRAPI BACKEND
# --------------------------------------------
VITE_STRAPI_URL=http://localhost:1337
VITE_USE_STRAPI=true


# --------------------------------------------
# GOOGLE TAG MANAGER
# --------------------------------------------
# Container ID proporcionado por el cliente (ej: GTM-XXXXXXX)
VITE_GTM_ID=GTM-5MG9W4PF

# --------------------------------------------
# CONVERSIÓN DE MONEDA
# --------------------------------------------
# Monedas: EUR (base), USD, MXN
# API Key (opcional - sin ella usa tasas de fallback)
# Registro gratis: https://www.exchangerate-api.com/
VITE_EXCHANGE_RATE_API_KEY=
